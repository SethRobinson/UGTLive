<Window x:Class="UGTLive.ExitConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UGTLive"
        mc:Ignorable="d"
        Title="Exit UGT Live"
        SizeToContent="Height"
        Width="460"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Background="White"
        BorderBrush="#CCCCCC"
        BorderThickness="1">
    <StackPanel Margin="25,20,25,18">
        <TextBlock Text="Are you sure you want to quit UGT Live?"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#1E1E6E"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <TextBlock Text="What should happen to the GPU services when the app closes?"
                   FontSize="12"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <RadioButton x:Name="closeAllRadio"
                     GroupName="GpuExit"
                     Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Close all GPU Services" FontWeight="SemiBold"/>
                <TextBlock Text="Stop every running GPU service, including any that were already running before UGT Live started."
                           FontSize="11" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="closeOwnedRadio"
                     GroupName="GpuExit"
                     IsChecked="True"
                     Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Close GPU Services we created (default)" FontWeight="SemiBold"/>
                <TextBlock Text="Stop only the GPU services that UGT Live started. Services that were already running are left alone."
                           FontSize="11" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="leaveRunningRadio"
                     GroupName="GpuExit"
                     Margin="0,0,0,4">
            <StackPanel>
                <TextBlock Text="Leave GPU Services running" FontWeight="SemiBold"/>
                <TextBlock Text="Exit without stopping any GPU service. They keep running in the background."
                           FontSize="11" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
        </RadioButton>

        <Grid Margin="0,18,0,0">
            <Button x:Name="backButton"
                    Content="Back"
                    Width="90" Height="30"
                    HorizontalAlignment="Left"
                    IsCancel="True"
                    Click="BackButton_Click"/>
            <Button x:Name="exitButton"
                    Content="Exit App"
                    Width="110" Height="30"
                    HorizontalAlignment="Right"
                    IsDefault="True"
                    FontWeight="SemiBold"
                    Click="ExitButton_Click"/>
        </Grid>
    </StackPanel>
</Window>
