<Window x:Class="UGTLive.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UGT Toolbar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        KeyboardNavigation.TabNavigation="None"
        Icon="/media/Icon1.ico">

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Background" Value="#FF5F5F5F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bgBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True"/>
                            <Border x:Name="hoverOverlay"
                                    Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hoverOverlay" Property="Background" Value="#30FFFFFF"/>
                                <Setter TargetName="bgBorder" Property="BorderBrush" Value="#FFAAAAAA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="hoverOverlay" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#CC202020" CornerRadius="4" BorderBrush="#80FF0000" BorderThickness="1" Padding="4">
        <StackPanel Orientation="Vertical" Width="110">
            <!-- Title bar: drag handle + minimize/close -->
            <DockPanel Height="16" Margin="0,0,0,4">
                <!-- Close button -->
                <Button x:Name="closeAppButton" DockPanel.Dock="Right" Content="✕" Width="18" Height="16"
                        Background="#CCE63232" Foreground="White" FontSize="9" FontWeight="Bold"
                        Padding="0" Margin="1,0,0,0" BorderThickness="0"
                        Click="CloseAppButton_Click"/>
                <!-- Minimize button -->
                <Button x:Name="minimizeAppButton" DockPanel.Dock="Right" Content="─" Width="18" Height="16"
                        Background="#40FFFFFF" Foreground="#CCFFFFFF" FontSize="9" FontWeight="Bold"
                        Padding="0" Margin="1,0,0,0" BorderThickness="0"
                        Click="MinimizeAppButton_Click"
                        ToolTip="Minimize (disables global hotkeys)"/>
                <!-- Drag handle fills remaining space -->
                <Border x:Name="DragHandle" Background="#40FFFFFF" CornerRadius="2" Cursor="SizeAll"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                    <TextBlock Text="· · ·" Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="10" FontWeight="Bold" IsHitTestVisible="False"/>
                </Border>
            </DockPanel>

            <!-- Primary action buttons -->
            <Button x:Name="snapshotButton" Content="Snap" Style="{StaticResource ToolbarButtonStyle}"
                    Click="SnapshotButton_Click"/>

            <Button x:Name="toggleButton" Content="Auto" Style="{StaticResource ToolbarButtonStyle}"
                    Click="ToggleButton_Click"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Window toggle buttons -->
            <Button x:Name="monitorButton" Content="Monitor" Style="{StaticResource ToolbarButtonStyle}"
                    Click="MonitorButton_Click"/>

            <Button x:Name="chatBoxButton" Content="Transcript" Style="{StaticResource ToolbarButtonStyle}"
                    Click="ChatBoxButton_Click"/>

            <Button x:Name="exportButton" Content="Browser" Style="{StaticResource ToolbarButtonStyle}"
                    Click="ExportButton_Click" ToolTip="View in browser"/>

            <Button x:Name="listenButton" Content="Listen" Style="{StaticResource ToolbarButtonStyle}"
                    Click="ListenButton_Click"/>

            <Button x:Name="logButton" Content="Log" Style="{StaticResource ToolbarButtonStyle}"
                    Click="LogButton_Click"/>

            <Button x:Name="settingsButton" Content="Settings" Style="{StaticResource ToolbarButtonStyle}"
                    Click="SettingsButton_Click"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Play All Audio -->
            <Button x:Name="playAllAudioButton" Content="🔊 All" Style="{StaticResource ToolbarButtonStyle}"
                    Click="PlayAllAudioButton_Click"
                    ToolTip="Play all audio files in order"/>

            <!-- Passthrough -->
            <CheckBox x:Name="mousePassthroughCheckBox" Content="Passthrough" Foreground="White"
                      Margin="4,2" FontSize="11"
                      Checked="MousePassthroughCheckBox_Changed" Unchecked="MousePassthroughCheckBox_Changed"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Overlay controls -->
            <TextBlock Text="Overlay:" Foreground="#AAFFFFFF" FontSize="10" Margin="4,2,0,2"/>
            <RadioButton x:Name="overlayHideRadio" Content="Hide" Foreground="White" Margin="4,1"
                         GroupName="ToolbarOverlayMode" Tag="Hide" FontSize="11"
                         Checked="OverlayRadioButton_Checked"/>
            <RadioButton x:Name="overlaySourceRadio" Content="Source" Foreground="White" Margin="4,1"
                         GroupName="ToolbarOverlayMode" Tag="Source" FontSize="11"
                         Checked="OverlayRadioButton_Checked"/>
            <RadioButton x:Name="overlayTranslatedRadio" Content="Translated" Foreground="White" Margin="4,1"
                         GroupName="ToolbarOverlayMode" Tag="Translated" FontSize="11"
                         Checked="OverlayRadioButton_Checked"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Hide red border toggle -->
            <Button x:Name="hideButton" Content="Hide red border" Style="{StaticResource ToolbarButtonStyle}"
                    Click="HideButton_Click"/>

            <!-- Draw red border (select capture area) -->
            <Button x:Name="drawBorderButton" Content="Draw red border" Style="{StaticResource ToolbarButtonStyle}"
                    Click="DrawBorderButton_Click"/>

        </StackPanel>
    </Border>
</Window>
