<Window x:Class="UGTLive.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UGT Toolbar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        KeyboardNavigation.TabNavigation="None"
        Icon="/media/Icon1.ico">

    <Border Background="#CC202020" CornerRadius="4" BorderBrush="#80FF0000" BorderThickness="1" Padding="4">
        <StackPanel Orientation="Vertical" Width="110">
            <!-- Drag handle -->
            <Border x:Name="DragHandle" Background="#40FFFFFF" CornerRadius="2" Height="14" Margin="0,0,0,4" Cursor="SizeAll"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <TextBlock Text="· · ·" Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="10" FontWeight="Bold" IsHitTestVisible="False"/>
            </Border>

            <!-- Primary action buttons -->
            <Button x:Name="snapshotButton" Content="Snap" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="SnapshotButton_Click" FontSize="11"/>

            <Button x:Name="toggleButton" Content="Auto" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="ToggleButton_Click" FontSize="11"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Window toggle buttons -->
            <Button x:Name="monitorButton" Content="Monitor" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="MonitorButton_Click" FontSize="11"/>

            <Button x:Name="chatBoxButton" Content="Transcript" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="ChatBoxButton_Click" FontSize="11"/>

            <Button x:Name="exportButton" Content="Browser" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="ExportButton_Click" FontSize="11" ToolTip="View in browser"/>

            <Button x:Name="listenButton" Content="Listen" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="ListenButton_Click" FontSize="11"/>

            <Button x:Name="logButton" Content="Log" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="LogButton_Click" FontSize="11"/>

            <Button x:Name="settingsButton" Content="Settings" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="SettingsButton_Click" FontSize="11"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Play All Audio -->
            <Button x:Name="playAllAudioButton" Content="🔊 All" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="PlayAllAudioButton_Click" FontSize="11"
                    ToolTip="Play all audio files in order"/>

            <!-- Passthrough -->
            <CheckBox x:Name="mousePassthroughCheckBox" Content="Passthrough" Foreground="White"
                      Margin="4,2" FontSize="11"
                      Checked="MousePassthroughCheckBox_Changed" Unchecked="MousePassthroughCheckBox_Changed"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Overlay controls -->
            <TextBlock Text="Overlay:" Foreground="#AAFFFFFF" FontSize="10" Margin="4,2,0,2"/>
            <RadioButton x:Name="overlayHideRadio" Content="Hide" Foreground="White" Margin="4,1"
                         GroupName="ToolbarOverlayMode" Tag="Hide" FontSize="11"
                         Checked="OverlayRadioButton_Checked"/>
            <RadioButton x:Name="overlaySourceRadio" Content="Source" Foreground="White" Margin="4,1"
                         GroupName="ToolbarOverlayMode" Tag="Source" FontSize="11"
                         Checked="OverlayRadioButton_Checked"/>
            <RadioButton x:Name="overlayTranslatedRadio" Content="Translated" Foreground="White" Margin="4,1"
                         GroupName="ToolbarOverlayMode" Tag="Translated" FontSize="11"
                         Checked="OverlayRadioButton_Checked"/>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#40FFFFFF" Margin="4,3"/>

            <!-- Hide toolbar -->
            <Button x:Name="hideButton" Content="Hide" Padding="4,3" Margin="1"
                    Background="#FF5F5F5F" Foreground="White" BorderThickness="1" BorderBrush="White"
                    Click="HideButton_Click" FontSize="11"/>
        </StackPanel>
    </Border>
</Window>
