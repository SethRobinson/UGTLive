<Window x:Class="UGTLive.ChatBoxOptionsWindow"         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UGTLive"
        mc:Ignorable="d"
        Title="Transcript Options" Height="420" Width="550"
        MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Icon="/media/Icon1.ico">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Transcript Appearance Options" 
                   Grid.Row="0"
                   FontSize="16" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Background settings -->
                <GroupBox Header="Background Settings" Margin="0,5,0,10" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Background Color:" Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5">
                            <Button x:Name="backgroundColorButton" 
                                    Width="30" Height="20" 
                                    Click="BackgroundColorButton_Click"/>
                            <TextBlock x:Name="backgroundColorText" 
                                       Text="#80000000" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Text="Background Opacity:" Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <Slider x:Name="backgroundOpacitySlider" Grid.Row="1" Grid.Column="1"
                                Minimum="0" Maximum="1" 
                                Value="0.5" 
                                VerticalAlignment="Center" Margin="0,5"
                                TickPlacement="BottomRight"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                ValueChanged="BackgroundOpacitySlider_ValueChanged"/>
                        <TextBlock x:Name="backgroundOpacityText" Grid.Row="1" Grid.Column="2"
                                   Text="50%" 
                                   VerticalAlignment="Center" 
                                   Margin="10,5,0,5" MinWidth="40"/>
                        
                        <TextBlock Text="Window Opacity:" Grid.Row="2" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <Slider x:Name="windowOpacitySlider" Grid.Row="2" Grid.Column="1"
                                Minimum="0.1" Maximum="1" 
                                Value="1.0" 
                                VerticalAlignment="Center" Margin="0,5"
                                TickPlacement="BottomRight"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="WindowOpacitySlider_ValueChanged"/>
                        <TextBlock x:Name="windowOpacityText" Grid.Row="2" Grid.Column="2"
                                   Text="100%" 
                                   VerticalAlignment="Center" 
                                   Margin="10,5,0,5" MinWidth="40"/>
                    </Grid>
                </GroupBox>

                <!-- Text settings -->
                <GroupBox Header="Text Settings" Margin="0,5,0,10" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Font Family:" Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <ComboBox x:Name="fontFamilyComboBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                  Margin="0,5"
                                  SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                        
                        <TextBlock Text="Font Size:" Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <Slider x:Name="fontSizeSlider" Grid.Row="1" Grid.Column="1"
                                Minimum="8" Maximum="48" 
                                Value="14" 
                                VerticalAlignment="Center" Margin="0,5"
                                TickPlacement="BottomRight"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                ValueChanged="FontSizeSlider_ValueChanged"/>
                        <TextBlock x:Name="fontSizeText" Grid.Row="1" Grid.Column="2"
                                   Text="14" 
                                   VerticalAlignment="Center" 
                                   Margin="10,5,0,5" MinWidth="40"/>
                    </Grid>
                </GroupBox>

                <!-- Original text color -->
                <GroupBox Header="Original Text Settings" Margin="0,5,0,10" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="Text Color:" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,5">
                            <Button x:Name="originalTextColorButton" 
                                    Width="30" Height="20" 
                                    Click="OriginalTextColorButton_Click"/>
                            <TextBlock x:Name="originalTextColorText" 
                                       Text="#FFF8E0A0" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Translated text color -->
                <GroupBox Header="Translated Text Settings" Margin="0,5,0,10" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="Text Color:" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,5">
                            <Button x:Name="translatedTextColorButton" 
                                    Width="30" Height="20" 
                                    Click="TranslatedTextColorButton_Click"/>
                            <TextBlock x:Name="translatedTextColorText" 
                                       Text="#FFFFFFFF" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons section -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="defaultsButton" 
                    Content="Set Defaults" 
                    Width="100" 
                    Height="25" 
                    HorizontalAlignment="Left"
                    Click="DefaultsButton_Click"
                    ToolTip="Reset all settings to default values"
                    Grid.Column="0"/>
            
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Grid.Column="1">
                <Button x:Name="applyButton" 
                        Content="Apply" 
                        Width="80" 
                        Height="25" 
                        Margin="5,0" 
                        Click="ApplyButton_Click"/>
                <Button x:Name="cancelButton" 
                        Content="Cancel" 
                        Width="80" 
                        Height="25" 
                        Margin="5,0" 
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>