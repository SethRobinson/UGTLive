<Window x:Class="UGTLive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UGTLive"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Transparent Screen Capture" 
        Height="{Binding InitialHeight}" Width="{Binding InitialWidth}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        KeyboardNavigation.TabNavigation="None"
        Icon="/media/Icon1.ico">
    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="15" CaptionHeight="10" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
      
    
    <Grid Background="Transparent">
        <!-- UI elements to hide during capture - HIDDEN DURING SCREENSHOT -->
        <!-- Note: Grid needs a background (even 1% opacity) for WebView2 hit testing to work in transparent windows -->
        <!-- OverlayContent is outside MainBorder so it remains visible when MainBorder is hidden -->
        <!-- Margins: Left=15, Top=50 (fixed header: 10px resize + 40px bar), Right=15, Bottom=15 -->
        <Grid Name="OverlayContent" Margin="15,50,15,15" IsHitTestVisible="True" Background="#01000000">
            <!-- WebView2 for text overlays - no margin, fills entire OverlayContent -->
            <!-- Capture rect is calculated to match WebView's exact screen position -->
            <wv2:WebView2 x:Name="textOverlayWebView" 
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          DefaultBackgroundColor="Transparent"
                          Margin="0"
                          IsHitTestVisible="True"
                          Panel.ZIndex="100"/>
        </Grid>
        
        <!-- Main border for resizing - can be hidden via Hide button -->
        <!-- Higher Z-index ensures buttons are clickable above the overlay -->
        <Border Name="MainBorder" BorderThickness="1" BorderBrush="#CFFF0000" Background="Transparent" Panel.ZIndex="200">
            <Grid>
                <!-- Top control bar with auto-sizing grid -->
                <Grid x:Name="TopControlGrid" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10"/>
                        <!-- Resize strip -->
                        <RowDefinition Height="Auto"/>
                        <!-- Fixed-height header bar -->
                    </Grid.RowDefinitions>
                    
                    <!-- Top resize strip - 10px height -->
                    <Border Grid.Row="0" Background="#50FF0000" Cursor="SizeNS"
                           WindowChrome.IsHitTestVisibleInChrome="False"/>
                    
                    <!-- Fixed-height header bar (no wrapping) -->
                    <Border Grid.Row="1" x:Name="HeaderBorder" Background="#CC202020" Height="40"
                            MouseLeftButtonDown="Header_MouseLeftButtonDown"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ClipToBounds="True">
                        <DockPanel Margin="5,0">
                            <!-- Close button - docked rightmost, disappears last -->
                            <Button DockPanel.Dock="Right" Content="X" Width="30" Height="30" Margin="2,5,2,5"
                                    Background="#CCE63232" Foreground="White" FontWeight="Bold"
                                    Click="CloseButton_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>

                            <!-- Minimize button -->
                            <Button x:Name="minimizeButton" DockPanel.Dock="Right" Content="─" Width="30" Height="30" Margin="0,5,0,5"
                                    Background="#CC5F5F5F" Foreground="White" FontWeight="Bold"
                                    Click="MinimizeButton_Click" WindowChrome.IsHitTestVisibleInChrome="True"
                                    ToolTip="Minimize (disables global hotkeys)"/>

                            <!-- Status display fills remaining space -->
                            <Border x:Name="translationStatusBorder"
                                    Background="#DD404040"
                                    Padding="8,2,8,2"
                                    CornerRadius="3"
                                    BorderThickness="1"
                                    BorderBrush="#666666"
                                    Visibility="Visible"
                                    VerticalAlignment="Center"
                                    Margin="0,0,5,0"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <StackPanel>
                                    <TextBlock x:Name="translationStatusLabel"
                                               Foreground="#FFDDDDDD"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="Stopped"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <ProgressBar x:Name="translationProgressBar"
                                                 Height="3"
                                                 IsIndeterminate="False"
                                                 Margin="0,2,0,0"
                                                 Visibility="Collapsed"
                                                 Foreground="#FF2EA043"
                                                 Background="#33FFFFFF"
                                                 BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
                
                <!-- Resize grip indicators -->
                <Rectangle Width="24" Height="24" Fill="#80808080"
                          HorizontalAlignment="Right" VerticalAlignment="Bottom"
                          Cursor="SizeNWSE"/>
                
                <!-- Resize borders - visual indicators only -->
                <Border BorderBrush="#8FFF0000" BorderThickness="7" Background="Transparent" IsHitTestVisible="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>