<Window x:Class="UGTLive.BatchConverterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Converter"
        Height="700" Width="750"
        MinHeight="550" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/media/Icon1.ico"
        AllowDrop="True" Drop="FileListBox_Drop" DragOver="FileListBox_DragOver">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header / Settings summary -->
        <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="5" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#90CAF9" Margin="0,0,0,6">Current Settings</TextBlock>
                <WrapPanel>
                    <TextBlock x:Name="settingsSourceLang" Margin="0,0,16,0" Foreground="#CCC"/>
                    <TextBlock x:Name="settingsTargetLang" Margin="0,0,16,0" Foreground="#CCC"/>
                    <TextBlock x:Name="settingsOcrMethod" Margin="0,0,16,0" Foreground="#CCC"/>
                    <TextBlock x:Name="settingsTransService" Margin="0,0,16,0" Foreground="#CCC"/>
                    <TextBlock x:Name="settingsContext" Foreground="#CCC"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,8,0">JPEG Quality:</TextBlock>
                    <Slider x:Name="jpegQualitySlider" Width="140" Minimum="50" Maximum="100"
                            TickFrequency="5" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="jpegQualityLabel" Foreground="#CCC" VerticalAlignment="Center" Width="28"/>
                    <TextBlock Foreground="#777" VerticalAlignment="Center" FontSize="11"
                               Margin="4,0,0,0">(for CBZ/PDF output — lower = smaller file)</TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <CheckBox x:Name="pageLimitCheckBox" Foreground="#CCC" VerticalAlignment="Center"
                              Margin="0,0,8,0" Content="Limit PDF/CBZ to first"/>
                    <TextBox x:Name="pageLimitTextBox" Width="40" Text="5" Foreground="White"
                             Background="#3C3C3C" BorderBrush="#555" Padding="4,2"
                             VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                    <TextBlock Foreground="#CCC" VerticalAlignment="Center" Margin="8,0,0,0">pages</TextBlock>
                    <TextBlock Foreground="#777" VerticalAlignment="Center" FontSize="11"
                               Margin="8,0,0,0">(useful for testing settings)</TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 1: Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="addFilesButton" Content="Add Files..." Padding="16,6" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555" Click="AddFilesButton_Click"/>
            <Button x:Name="addFolderButton" Content="Add Folder..." Padding="16,6" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555" Click="AddFolderButton_Click"/>
            <Button x:Name="removeSelectedButton" Content="Remove" Padding="16,6" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555" Click="RemoveSelectedButton_Click"/>
            <Button x:Name="clearAllButton" Content="Clear All" Padding="16,6"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555" Click="ClearAllButton_Click"/>
            <TextBlock x:Name="fileCountText" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#AAA"/>
        </StackPanel>

        <!-- Row 2: File list (supports drag-and-drop) -->
        <Grid Grid.Row="2">
            <ListBox x:Name="fileListBox" Background="#252526" Foreground="White"
                     BorderBrush="#3C3C3C" SelectionMode="Extended"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     AllowDrop="True" Drop="FileListBox_Drop" DragOver="FileListBox_DragOver">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Status}" Width="80" Foreground="#888" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DisplayText}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock x:Name="dragDropHint" Text="Drag and drop files or folders here"
                       Foreground="#555" FontSize="14" FontStyle="Italic"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- Row 3: Status text (selectable) -->
        <TextBox x:Name="statusText" Grid.Row="3" Margin="0,8,0,4" Foreground="#90CAF9" FontSize="13"
                 Background="Transparent" BorderThickness="0" IsReadOnly="True"
                 TextWrapping="NoWrap"/>

        <!-- Row 4: Progress bar -->
        <ProgressBar x:Name="progressBar" Grid.Row="4" Height="22" Margin="0,0,0,4"
                     Background="#333" Foreground="#4CAF50" BorderBrush="#555"/>

        <!-- Row 5: Preview label -->
        <TextBlock Grid.Row="5" Text="Preview:" Foreground="#888" Margin="0,4,0,2" FontSize="11"/>

        <!-- Row 6: Preview + Log area -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" Margin="0,0,4,0">
                <Image x:Name="previewImage" Stretch="Uniform"/>
            </Border>
            <Border Grid.Column="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" Margin="4,0,0,0">
                <TextBox x:Name="logTextBox" TextWrapping="Wrap" Foreground="#AAA" FontSize="11"
                         Background="Transparent" BorderThickness="0" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto" Padding="6"/>
            </Border>
        </Grid>

        <!-- Row 7: Action buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="openFolderButton" Content="Open Output Folder" Padding="16,8" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555"
                    Visibility="Collapsed" Click="OpenFolderButton_Click"/>
            <Button x:Name="openTempFolderButton" Content="Open Temp Folder" Padding="16,8" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555"
                    Visibility="Collapsed" Click="OpenTempFolderButton_Click"/>
            <Button x:Name="startButton" Content="Start" Padding="24,8" Margin="0,0,8,0"
                    Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                    FontWeight="Bold" FontSize="14" Click="StartButton_Click"/>
            <Button x:Name="cancelButton" Content="Cancel" Padding="24,8"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555"
                    FontSize="14" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>

</Window>
